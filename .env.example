# ── Required ────────────────────────────────────────────────
# Your bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# ── Optional ────────────────────────────────────────────────
# Path to the SQLite database file
DATABASE_PATH=bot_data.db

# Minimum seconds between counted messages per user (anti-spam cooldown)
COOLDOWN_SECONDS=5

# Minimum character length for a message to be counted
MIN_MESSAGE_LENGTH=3
